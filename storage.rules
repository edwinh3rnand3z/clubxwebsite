rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.superAdmin == true ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          (userProfile().data.role == "admin" || userProfile().data.role == "superAdmin"))
      );
    }

    match /user-images/{userId}/{fileName} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if isAdmin() && request.resource.size < 25 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }
  }
}
